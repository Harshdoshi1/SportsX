PORT=4000
NODE_ENV=development

RAPID_API_BASE_URL=https://cricket-api-free-data.p.rapidapi.com
RAPID_API_HOST=cricket-api-free-data.p.rapidapi.com
RAPID_API_KEY=replace_with_your_rapidapi_key

RAPID_API_TIMEOUT_MS=15000
CACHE_TTL_SECONDS=600
CACHE_CHECK_PERIOD_SECONDS=120
RETRY_COUNT=2
RETRY_DELAY_MS=400

TEAM_IMAGE_DIR=public/assets/teams
TEAM_IMAGE_BASE_URL=/assets/teams

# Create this folder and add player images if not present.
PLAYER_IMAGE_DIR=public/assets/players
PLAYER_IMAGE_BASE_URL=/assets/players

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Dev-only fallback when service role key is not available and RLS write policies allow anon.
SUPABASE_ALLOW_PUBLISHABLE_WRITES=false

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key

SYNC_INTERVAL_MS=300000
TEAM_SYNC_INTERVAL_MS=300000
HEARTBEAT_INTERVAL_MS=86400000
IPL_SEASON_YEAR=2026
